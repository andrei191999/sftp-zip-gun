# Playwright E2E test runtime overrides.
# Copy to .env and tweak. .env is gitignored; .env.example is committed.
# npm script variants (test:e2e:debug, :debug:slow, :parallel, ...) override these.

# 1 = visible Electron window (default), 0 = headless
HEADED=1

# Per-action delay in ms (0 = full speed). Try 1500 for debug, 3000 for narration speed.
SLOW_MO=0

# 1 = draw a red outline on each clicked element before the action. Pairs with SLOW_MO.
HIGHLIGHT=0

# 1 = record a Playwright trace per test. Open with: npx playwright show-trace test-results/.../trace.zip
TRACE=0

# Parallel workers. 1–4 supported. Headed parallel works (multiple VS Code windows) but is CPU-heavy.
# Artifacts are isolated under /store/e2e/... and inspectable at %TEMP%\sftp-zip-gun-qa\data\<user>\store\e2e.
WORKERS=1

# Per-test timeout in ms (default 120000).
E2E_TIMEOUT=120000
